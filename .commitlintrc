{
  "extends": ["@commitlint/config-conventional"],
  "rules": {
    "type-enum": [
      2,
      "always",
      [
        "feat", 
        "fix", 
        "style",
        "docs", 
        "refactor", 
        "test", 
        "chore", 
        "perf",
        "build",
        "ci", 
        "revert"
      ]
    ],
    "body-max-line-length": [1, "always", 100],
    "subject-case": [0],
    "scope-case": [2, "always", ["pascal-case", "kebab-case", "upper-case", "lower-case"]]
  }
}